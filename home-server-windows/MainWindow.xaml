<Window
    x:Class="GoHome.HomeServer.Windows.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Go Home 家庭服务器">
    <Grid Background="#0B1110">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Padding="28,24" BorderBrush="#203B36" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="14">
                <Border Width="48" Height="48" CornerRadius="10" Background="#123F37">
                    <TextBlock Text="GH" Foreground="#79F0D0" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel>
                    <TextBlock Text="Go Home 家庭服务器" Foreground="#F2FBF8" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock Text="Windows 管理端，使用 Go 核心连接公网服务器" Foreground="#93AAA4" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Padding="28">
            <Grid x:Name="ConnectPanel" MaxWidth="720" HorizontalAlignment="Left" VerticalAlignment="Top">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock Text="公网服务器 WebSocket 地址" Foreground="#BFD2CD"/>
                        <TextBox x:Name="ServerBox" PlaceholderText="ws://YOUR_PUBLIC_SERVER:8080/ws"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="授权码" Foreground="#BFD2CD"/>
                        <PasswordBox x:Name="AuthCodeBox" PlaceholderText="输入公网服务器授权码"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="家庭网段，可留空自动检测" Foreground="#BFD2CD"/>
                        <TextBox x:Name="LanCidrBox" PlaceholderText="例如 192.168.3.0/24"/>
                    </StackPanel>
                    <StackPanel Spacing="6">
                        <TextBlock Text="家庭网卡，可留空自动检测" Foreground="#BFD2CD"/>
                        <TextBox x:Name="LanInterfaceBox" PlaceholderText="例如 Ethernet"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="ConnectButton" Content="连接" Click="ConnectButton_Click" MinWidth="136"/>
                        <ProgressRing x:Name="LoadingRing" Width="32" Height="32" IsActive="False"/>
                    </StackPanel>
                    <TextBlock x:Name="ConnectHint" Foreground="#93AAA4" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <Grid x:Name="StatsPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Content="断开" Click="DisconnectButton_Click"/>
                    <TextBlock x:Name="StatusText" Foreground="#79F0D0" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>
                <Grid Grid.Row="1" Margin="0,22,0,22" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#121D1A" BorderBrush="#264740" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Text="已连接客户端" Foreground="#93AAA4"/>
                            <TextBlock x:Name="ClientCountText" Text="0" Foreground="#F2FBF8" FontSize="30" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#121D1A" BorderBrush="#264740" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Text="上行流量" Foreground="#93AAA4"/>
                            <TextBlock x:Name="UpText" Text="0 B" Foreground="#F2FBF8" FontSize="30" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#121D1A" BorderBrush="#264740" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <TextBlock Text="下行流量" Foreground="#93AAA4"/>
                            <TextBlock x:Name="DownText" Text="0 B" Foreground="#F2FBF8" FontSize="30" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <ListView x:Name="ClientsList" Grid.Row="2">
                    <ListView.Header>
                        <TextBlock Text="客户端 IP 与流量" Foreground="#BFD2CD" FontSize="16" Margin="0,0,0,8"/>
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ClientRow" xmlns:local="using:GoHome.HomeServer.Windows">
                            <Grid Padding="10" ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind DeviceId}" Foreground="#F2FBF8"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind Ip}" Foreground="#BFD2CD"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind Up}" Foreground="#BFD2CD"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind Down}" Foreground="#BFD2CD"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Window>
